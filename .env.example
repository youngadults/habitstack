# StackFlow Environment Variables

# Supabase Configuration (optional — app works offline without these)
# If not set, the app runs in local mode (data stored in browser only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side (for SSR, only needed with Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=